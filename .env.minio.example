# Copy to .env.minio and adjust if ports conflict with existing containers.
# Used only by docker-compose.minio.yml (standalone MinIO stack).

MINIO_ROOT_USER=tuadmin
MINIO_ROOT_PASSWORD=tu123456
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Match these in tu-backend when running locally (see .env.example STORAGE_*).
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_ACCESS_KEY=tuadmin
STORAGE_S3_SECRET_KEY=tu123456
STORAGE_S3_BUCKET=tu-files
